{
  "version": 2,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/mat/(.*)", "dest": "/mat/$1" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
